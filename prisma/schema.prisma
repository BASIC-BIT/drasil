generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_actions {
  id                    String               @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id             String?
  user_id               String?
  admin_id              String
  verification_event_id String?              @db.Uuid
  detection_event_id    String?              @db.Uuid
  action_type           admin_action_type
  action_at             DateTime?            @default(now()) @db.Timestamptz(6)
  previous_status       verification_status?
  new_status            verification_status?
  notes                 String?
  metadata              Json?                @default("{}")
  detection_events      detection_events?    @relation(fields: [detection_event_id], references: [id], onUpdate: NoAction)
  servers               servers?             @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                 users?               @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)
  verification_events   verification_events? @relation(fields: [verification_event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([admin_id], map: "idx_admin_actions_admin")
  @@index([detection_event_id], map: "idx_admin_actions_detection")
  @@index([server_id], map: "idx_admin_actions_server")
  @@index([user_id], map: "idx_admin_actions_user")
  @@index([verification_event_id], map: "idx_admin_actions_verification")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model detection_events {
  id                                                                                     String                   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id                                                                              String?
  user_id                                                                                String?
  detection_type                                                                         detection_type
  confidence                                                                             Float                    @db.Real
  detected_at                                                                            DateTime?                @default(now()) @db.Timestamptz(6)
  message_id                                                                             String?
  channel_id                                                                             String?
  thread_id                                                                              String?
  reasons                                                                                String[]
  metadata                                                                               Json?                    @default("{}")
  admin_action                                                                           String?
  admin_action_by                                                                        String?
  admin_action_at                                                                        DateTime?                @db.Timestamptz(6)
  latest_verification_event_id                                                           String?                  @db.Uuid
  admin_actions                                                                          admin_actions[]
  moderation_outcomes                                                                    moderation_outcomes[]
  moderation_queue_items                                                                 moderation_queue_items[]
  servers                                                                                servers?                 @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                                                                                  users?                   @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)
  verification_events_detection_events_latest_verification_event_idToverification_events verification_events?     @relation("detection_events_latest_verification_event_idToverification_events", fields: [latest_verification_event_id], references: [id], onUpdate: NoAction, map: "fk_detection_events_verification")
  verification_events_verification_events_detection_event_idTodetection_events           verification_events[]    @relation("verification_events_detection_event_idTodetection_events")

  @@index([detected_at], map: "idx_detection_events_detected_at")
  @@index([detected_at], map: "idx_detection_events_detected_at_range", type: Brin)
  @@index([latest_verification_event_id], map: "idx_detection_events_latest_verification")
  @@index([server_id], map: "idx_detection_events_server")
  @@index([detection_type], map: "idx_detection_events_type")
  @@index([user_id], map: "idx_detection_events_user")
  @@index([user_id, server_id, detection_type], map: "idx_detection_events_user_server_type")
}

model moderation_queue_items {
  id                     String                     @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id              String
  user_id                String
  item_type              moderation_queue_item_type
  verification_event_id  String?                    @db.Uuid
  detection_event_id     String?                    @db.Uuid
  report_intake_id       String?                    @db.Uuid
  source_thread_id       String?
  queue_channel_id       String?
  queue_message_id       String?
  last_source_message_id String?
  last_notified_at       DateTime?                  @db.Timestamptz(6)
  created_at             DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                  @default(now()) @db.Timestamptz(6)
  metadata               Json?                      @default("{}")
  detection_events       detection_events?          @relation(fields: [detection_event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  report_intakes         report_intakes?            @relation(fields: [report_intake_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  servers                servers                    @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                  users                      @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)
  verification_events    verification_events?       @relation(fields: [verification_event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([detection_event_id], map: "idx_moderation_queue_items_detection")
  @@index([item_type], map: "idx_moderation_queue_items_type")
  @@index([queue_channel_id, queue_message_id], map: "idx_moderation_queue_items_queue_message")
  @@index([report_intake_id], map: "idx_moderation_queue_items_report_intake")
  @@index([server_id], map: "idx_moderation_queue_items_server")
  @@index([source_thread_id], map: "idx_moderation_queue_items_thread")
  @@index([user_id], map: "idx_moderation_queue_items_user")
  @@index([verification_event_id], map: "idx_moderation_queue_items_verification")
}

model role_quarantine_snapshots {
  id                    String                          @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id             String
  user_id               String
  verification_event_id String?                         @db.Uuid
  status                role_quarantine_snapshot_status @default(active)
  mode                  String                          @default("automatic")
  original_role_ids     String[]                        @default([])
  planned_role_ids      String[]                        @default([])
  removed_role_ids      String[]                        @default([])
  restored_role_ids     String[]                        @default([])
  skipped_roles         Json?                           @default("[]")
  failed_removals       Json?                           @default("[]")
  failed_restores       Json?                           @default("[]")
  created_at            DateTime?                       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?                       @default(now()) @db.Timestamptz(6)
  restored_at           DateTime?                       @db.Timestamptz(6)
  restored_by           String?
  metadata              Json?                           @default("{}")
  servers               servers                         @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                 users                           @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)
  verification_events   verification_events?            @relation(fields: [verification_event_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([server_id], map: "idx_role_quarantine_snapshots_server")
  @@index([status], map: "idx_role_quarantine_snapshots_status")
  @@index([user_id], map: "idx_role_quarantine_snapshots_user")
  @@index([server_id, user_id, status], map: "idx_role_quarantine_snapshots_user_status")
  @@index([verification_event_id], map: "idx_role_quarantine_snapshots_verification")
}

model message_contexts {
  id               String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id        String
  user_id          String
  message_id       String
  channel_id       String?
  content_preview  String
  content_features Json?    @default("{}")
  created_at       DateTime @db.Timestamptz(6)
  observed_at      DateTime @default(now()) @db.Timestamptz(6)
  expires_at       DateTime @db.Timestamptz(6)

  @@unique([server_id, message_id], map: "message_contexts_server_message_key")
  @@index([expires_at], map: "idx_message_contexts_expires_at")
  @@index([server_id, user_id, created_at], map: "idx_message_contexts_server_user_created_at")
  @@index([server_id, created_at], map: "idx_message_contexts_server_created_at")
}

model moderation_outcomes {
  id                    String                    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id             String
  user_id               String
  detection_event_id    String?                   @db.Uuid
  verification_event_id String?                   @db.Uuid
  outcome_type          moderation_outcome_type
  source                moderation_outcome_source
  actor_id              String?
  reason                String?
  occurred_at           DateTime?                 @default(now()) @db.Timestamptz(6)
  created_at            DateTime?                 @default(now()) @db.Timestamptz(6)
  metadata              Json?                     @default("{}")
  detection_events      detection_events?         @relation(fields: [detection_event_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  servers               servers                   @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                 users                     @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)
  verification_events   verification_events?      @relation(fields: [verification_event_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([actor_id], map: "idx_moderation_outcomes_actor")
  @@index([detection_event_id], map: "idx_moderation_outcomes_detection")
  @@index([occurred_at], map: "idx_moderation_outcomes_occurred_at")
  @@index([outcome_type], map: "idx_moderation_outcomes_type")
  @@index([server_id], map: "idx_moderation_outcomes_server")
  @@index([source], map: "idx_moderation_outcomes_source")
  @@index([user_id], map: "idx_moderation_outcomes_user")
  @@index([user_id, server_id, outcome_type], map: "idx_moderation_outcomes_user_server_type")
  @@index([verification_event_id], map: "idx_moderation_outcomes_verification")
}

model global_message_watchlist_entries {
  id                     String    @id
  label                  String
  term                   String
  enabled                Boolean   @default(true)
  requires_link_or_video Boolean   @default(true)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  updated_at             DateTime? @default(now()) @db.Timestamptz(6)
  created_by             String?
  updated_by             String?

  @@index([enabled], map: "idx_global_message_watchlist_entries_enabled")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model server_members {
  server_id                              String
  user_id                                String
  join_date                              DateTime?            @db.Timestamptz(6)
  reputation_score                       Float?               @default(0.0) @db.Real
  case_role_active                       Boolean?             @default(false)
  last_verified_at                       DateTime?            @db.Timestamptz(6)
  last_message_at                        DateTime?            @db.Timestamptz(6)
  message_count                          Int?                 @default(0)
  verification_status                    verification_status? @default(pending)
  last_status_change                     DateTime?            @db.Timestamptz(6)
  discord_member_pending                 Boolean              @default(false)
  discord_member_pending_since           DateTime?            @db.Timestamptz(6)
  discord_member_pending_cleared_at      DateTime?            @db.Timestamptz(6)
  discord_member_pending_last_checked_at DateTime?            @db.Timestamptz(6)
  discord_member_pending_digest_sent_at  DateTime?            @db.Timestamptz(6)
  created_by                             String?
  updated_by                             String?
  servers                                servers              @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                                  users                @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([server_id, user_id])
  @@index([server_id, discord_member_pending, discord_member_pending_since], map: "idx_server_members_discord_pending")
  @@index([server_id], map: "idx_server_members_server")
  @@index([user_id], map: "idx_server_members_user")
  @@index([user_id, server_id, case_role_active], map: "idx_server_members_user_server_case_role")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model servers {
  guild_id                            String                      @id
  case_role_id                        String?
  admin_channel_id                    String?
  verification_channel_id             String?
  admin_notification_role_id          String?
  heuristic_message_threshold         Int                         @default(5)
  heuristic_message_timeframe_seconds Int                         @default(10)
  heuristic_suspicious_keywords       String[]                    @default(["nitro scam", "free discord nitro", "free nitro", "discord nitro", "steam gift", "gift card", "click this link", "claim your prize", "crypto giveaway", "airdrop", "free robux"])
  created_at                          DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                          DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_by                          String?
  settings                            Json?                       @default("{}")
  is_active                           Boolean?                    @default(true)
  admin_actions                       admin_actions[]
  detection_events                    detection_events[]
  moderation_outcomes                 moderation_outcomes[]
  moderation_queue_items              moderation_queue_items[]
  report_intakes                      report_intakes[]
  role_quarantine_snapshots           role_quarantine_snapshots[]
  server_members                      server_members[]
  verification_events                 verification_events[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  discord_id                String                      @id
  username                  String?
  created_at                DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?                   @default(now()) @db.Timestamptz(6)
  created_by                String?
  updated_by                String?
  global_reputation_score   Float?                      @db.Real
  suspicious_server_count   Int?                        @default(0)
  first_flagged_at          DateTime?                   @db.Timestamptz(6)
  account_created_at        DateTime?                   @db.Timestamptz(6)
  metadata                  Json?                       @default("{}")
  admin_actions             admin_actions[]
  detection_events          detection_events[]
  moderation_outcomes       moderation_outcomes[]
  moderation_queue_items    moderation_queue_items[]
  report_intakes            report_intakes[]
  role_quarantine_snapshots role_quarantine_snapshots[]
  server_members            server_members[]
  verification_events       verification_events[]
}

model report_intakes {
  id                       String                   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id                String
  reporter_id              String
  thread_id                String?                  @unique
  status                   report_intake_status     @default(collecting_evidence)
  summary                  String?
  confirmed_target_user_id String?
  created_at               DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                @default(now()) @db.Timestamptz(6)
  closed_at                DateTime?                @db.Timestamptz(6)
  metadata                 Json?                    @default("{}")
  moderation_queue_items   moderation_queue_items[]
  report_intake_evidence   report_intake_evidence[]
  servers                  servers                  @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                    users                    @relation(fields: [reporter_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([server_id], map: "idx_report_intakes_server")
  @@index([reporter_id], map: "idx_report_intakes_reporter")
  @@index([status], map: "idx_report_intakes_status")
}

model report_intake_evidence {
  id                String                      @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  intake_id         String                      @db.Uuid
  kind              report_intake_evidence_kind
  source_message_id String?
  source_channel_id String?
  attachment_id     String?
  content           String?
  metadata          Json?                       @default("{}")
  created_at        DateTime?                   @default(now()) @db.Timestamptz(6)
  report_intakes    report_intakes              @relation(fields: [intake_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([intake_id], map: "idx_report_intake_evidence_intake")
  @@index([kind], map: "idx_report_intake_evidence_kind")
  @@index([source_message_id], map: "idx_report_intake_evidence_message")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model verification_events {
  id                                                                                  String                      @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  server_id                                                                           String?
  user_id                                                                             String?
  detection_event_id                                                                  String?                     @db.Uuid
  thread_id                                                                           String?
  private_evidence_thread_id                                                          String?
  notification_channel_id                                                             String?
  notification_message_id                                                             String?
  status                                                                              verification_status         @default(pending)
  created_at                                                                          DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                                                                          DateTime?                   @default(now()) @db.Timestamptz(6)
  resolved_at                                                                         DateTime?                   @db.Timestamptz(6)
  resolved_by                                                                         String?
  notes                                                                               String?
  metadata                                                                            Json?                       @default("{}")
  admin_actions                                                                       admin_actions[]
  detection_events_detection_events_latest_verification_event_idToverification_events detection_events[]          @relation("detection_events_latest_verification_event_idToverification_events")
  detection_events_verification_events_detection_event_idTodetection_events           detection_events?           @relation("verification_events_detection_event_idTodetection_events", fields: [detection_event_id], references: [id], onUpdate: NoAction)
  moderation_outcomes                                                                 moderation_outcomes[]
  moderation_queue_items                                                              moderation_queue_items[]
  role_quarantine_snapshots                                                           role_quarantine_snapshots[]
  servers                                                                             servers?                    @relation(fields: [server_id], references: [guild_id], onDelete: Cascade, onUpdate: NoAction)
  users                                                                               users?                      @relation(fields: [user_id], references: [discord_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_verification_events_created_at_range", type: Brin)
  @@index([detection_event_id], map: "idx_verification_events_detection")
  @@index([notification_channel_id], map: "idx_verification_events_notification_channel")
  @@index([private_evidence_thread_id], map: "idx_verification_events_private_evidence_thread")
  @@index([server_id], map: "idx_verification_events_server")
  @@index([status], map: "idx_verification_events_status")
  @@index([thread_id], map: "idx_verification_events_thread")
  @@index([user_id], map: "idx_verification_events_user")
  @@index([user_id, server_id, status], map: "idx_verification_events_user_server_status")
}

enum admin_action_type {
  verify
  reject
  ban
  kick
  close_no_action
  reopen
  create_thread
  open_case
  restrict
  lift_restriction
  dismiss
  false_positive
  undo_observed_action
  role_gate_cleanup
}

enum detection_type {
  message_frequency
  suspicious_content
  gpt_analysis
  new_account
  rejoin_after_kick
  pattern_match
  user_report
  admin_case
  admin_flag
  role_intake
  honeypot_role
}

enum moderation_outcome_source {
  drasil
  native_discord
  external_bot
  unknown_external
  migration_or_sync
}

enum moderation_outcome_type {
  restricted
  verified
  banned
  kicked
  closed_no_action
  member_left
}

enum moderation_queue_item_type {
  case_mirror
  observed_alert_mirror
  support_thread_attention
  report_thread_attention
  pending_screening_member
}

enum role_quarantine_snapshot_status {
  active
  restored
  abandoned
}

enum report_intake_status {
  collecting_evidence
  needs_reporter_confirmation
  needs_admin_confirmation
  submitted
  closed_by_reporter
  actioned
  dismissed
  false_positive
  expired
}

enum report_intake_evidence_kind {
  reporter_text
  screenshot
  message_link
  reported_text
  followup_answer
  candidate_confirmation
  admin_note
}

enum verification_status {
  pending
  verified
  banned
  kicked
  closed_no_action
}
