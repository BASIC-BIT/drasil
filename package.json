{
  "name": "drasil",
  "version": "1.0.0",
  "private": true,
  "description": "A Discord bot that leverages GPT-based analysis and heuristic checks to proactively detect and mitigate spammers and scammers in Discord servers.",
  "main": "dist/index.js",
  "workspaces": [
    "apps/web",
    "packages/contracts"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "node --watch -r ts-node/register src/index.ts",
    "test": "jest --testPathPattern=src/__tests__/unit",
    "test:watch": "jest --watch --testPathPattern=src/__tests__/unit",
    "test:coverage": "jest --testPathPattern=src/__tests__/unit --coverage",
    "test:integration": "node scripts/run-integration-tests.js",
    "build": "tsc",
    "build:watch": "tsc -w",
    "clean": "rm -rf dist",
    "dev:env": "node scripts/hydrate-dev-env.js",
    "postinstall": "node scripts/prisma-generate-if-needed.js",
    "lint": "eslint . --ext .ts,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.js,.mjs --fix",
    "web:build": "npm --workspace apps/web run build",
    "web:lint": "npm --workspace apps/web run lint",
    "web:typecheck": "npm --workspace apps/web run typecheck",
    "web:test": "npm --workspace apps/web run test",
    "web:test:coverage": "npm --workspace apps/web run test:coverage",
    "web:storybook:build": "npm --workspace apps/web run storybook:build",
    "web:storybook:visual": "npm --workspace apps/web run test:storybook:visual",
    "web:storybook:visual:update": "npm --workspace apps/web run test:storybook:visual:update",
    "web:e2e": "npm --workspace apps/web run test:e2e",
    "web:e2e:visual": "npm --workspace apps/web run test:e2e:visual",
    "web:e2e:visual:update": "npm --workspace apps/web run test:e2e:visual:update",
    "contracts:build": "npm --workspace packages/contracts run build",
    "contracts:lint": "npm --workspace packages/contracts run lint",
    "contracts:typecheck": "npm --workspace packages/contracts run typecheck",
    "contracts:test": "npm --workspace packages/contracts run test",
    "contracts:test:coverage": "npm --workspace packages/contracts run test:coverage",
    "code:metrics": "bash scripts/check-metrics.sh",
    "format": "prettier --write \"**/*.{ts,js,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,mjs}\"",
    "check": "npm run lint:fix && npm run build && npm test",
    "check:full": "npm run format:check && npm run check && npm run test:integration",
    "check:ci": "npm run format:check && npm run lint && npm run build && npm test && npm run contracts:lint && npm run contracts:typecheck && npm run contracts:test:coverage && npm run web:lint && npm run web:typecheck && npm run web:test:coverage && npm run web:build && npm run web:storybook:build && npm run web:e2e && npm run web:e2e:visual && npm run web:storybook:visual && npm run test:integration && npm run db:check:rls",
    "prisma:generate": "node scripts/prisma-generate.js",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:db:pull": "prisma db pull",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "db:seed": "prisma db seed",
    "db:reset:local": "npx supabase db reset --local && node scripts/create-prisma-user.js && prisma migrate reset && npm run db:seed",
    "db:check:rls": "node scripts/check-public-rls.js",
    "intel:upload": "node scripts/upload-intel-case.js"
  },
  "keywords": [
    "discord",
    "bot",
    "anti-spam",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.27.0",
    "@eslint/js": "^9.23.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.5",
    "globals": "^16.0.0",
    "jest": "^29.5.0",
    "jest-mock-extended": "4.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.28.0"
  },
  "dependencies": {
    "@arizeai/openinference-instrumentation-openai": "^2.1.0",
    "@arizeai/phoenix-otel": "^0.3.4",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.49.3",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "inversify": "^7.2.0",
    "openai": "^4.89.0",
    "pg": "^8.20.0",
    "posthog-node": "^5.35.1",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.25.76"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
