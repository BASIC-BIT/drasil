# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Prisma / Postgres connection string (used by Prisma Client and migrations)
# Local Supabase default DB is usually on port 54322.
# Replace the password to match PRISMA_DB_PASSWORD.
DATABASE_URL="postgresql://prisma:replace-with-PRISMA_DB_PASSWORD@127.0.0.1:54322/postgres?schema=public"

# Node Environment
NODE_ENV=development

# Optional comma-separated Discord user IDs allowed to audit global detections
# DRASIL_GLOBAL_ADMIN_IDS=123456789012345678

# Optional pre-live/manual testing mode.
# Records detections and reports normally, but excludes new events from future accounting.
# Keep unset or false in production.
# DRASIL_DETECTION_TEST_MODE=false
# DRASIL_DETECTION_TEST_RUN_ID=manual-test-001

# Password for the dedicated 'prisma' database user (used during local reset)
PRISMA_DB_PASSWORD=replace-with-a-strong-password

# Connection string for the default 'postgres' user (used by integration tests to create extensions)
# Assumes standard Supabase local setup
POSTGRES_DB_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=public"

# Optional overrides for local DB bootstrap (used by scripts/create-prisma-user.js)
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=54322
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=postgres

# Phoenix (Arize) LLM observability (optional)
# Docs: docs/dev/phoenix.md
#
# Enable tracing explicitly:
# PHOENIX_TRACING_ENABLED=true
#
# Local collector:
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
#
# Phoenix Cloud / auth-enabled self-host:
# PHOENIX_API_KEY=
#
# Project name shown in Phoenix UI:
# PHOENIX_PROJECT_NAME=drasil-local
#
# Redact prompt/response content (recommended default):
# PHOENIX_HIDE_CONTENT=true
#
# Optional: stable pseudonymous hashing across restarts
# OBSERVABILITY_HASH_KEY=replace-with-a-random-secret

# PostHog product analytics (optional)
# Docs: docs/dev/posthog.md
# Product analytics only exports when a project token is configured.
# Server-level sharing defaults to anonymous and can be changed with /config analytics.
# POSTHOG_PROJECT_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PRODUCT_ANALYTICS_ENVIRONMENT=local
# POSTHOG_PRODUCT_ANALYTICS_ENABLED=true
# POSTHOG_DEBUG=false

# Web setup dashboard
# Required for local manual Discord OAuth testing. Playwright tests inject safe defaults.
NEXT_PUBLIC_APP_URL=http://localhost:3000
DISCORD_CLIENT_ID=your_discord_oauth_client_id_here
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret_here
DRASIL_SESSION_SECRET=replace-with-a-high-entropy-cookie-signing-secret
DRASIL_OAUTH_ENCRYPTION_KEY=replace-with-a-separate-high-entropy-encryption-secret

# Optional web overrides. If unset, the web app falls back to DATABASE_URL and DISCORD_TOKEN.
# DRASIL_WEB_DATABASE_URL="postgresql://prisma:replace-with-PRISMA_DB_PASSWORD@127.0.0.1:54322/postgres?schema=public"
# DRASIL_WEB_BOT_TOKEN=your_discord_bot_token_here
# DRASIL_WEB_PG_POOL_MAX=4
# DRASIL_WEB_DATA_PROVIDER=postgres

# Future Convex adapter path. Leave unset while Postgres is the active provider.
# DRASIL_CONVEX_HTTP_URL=
# DRASIL_CONVEX_WEB_API_KEY=
